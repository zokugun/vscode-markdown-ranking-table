{
	"name": "markdown-ranking-table",
	"displayName": "Markdown Ranking Table",
	"description": "Edit and reorder rankings in Markdown tables",
	"version": "0.1.0",
	"author": {
		"name": "Baptiste Augrain",
		"email": "daiyam@zokugun.org"
	},
	"publisher": "zokugun",
	"license": "MIT",
	"homepage": "https://github.com/zokugun/vscode-markdown-ranking-table",
	"repository": {
		"type": "git",
		"url": "https://github.com/zokugun/vscode-markdown-ranking-table.git"
	},
	"bugs": {
		"url": "https://github.com/zokugun/vscode-markdown-ranking-table/issues"
	},
	"engines": {
		"vscode": "^1.75.0"
	},
	"main": "./lib/index.js",
	"browser": "./lib/index.js",
	"scripts": {
		"audit:fix": "npm audit fix --min-release-age=0",
		"build": "npm run clean && npm run compile:src && npm run bundle",
		"bundle": "ncc build out/extension --out lib",
		"ci:lint": "zizmor .",
		"ci:lint:fix": "zizmor . --fix=all",
		"clean": "rimraf lib; rimraf out *.vsix",
		"compile:src": "tsc -p src",
		"lint": "xo",
		"lint:all": "npm run lint:package && npm audit && npm run ci:lint && npm run lint",
		"lint:fix": "xo --fix",
		"lint:package": "fixpack || true",
		"package": "rimraf *.vsix && vsce package",
		"prepare": "husky; npm run lint:package",
		"release": "release-it",
		"update:artifacts": "artifact update",
		"update:ci": "PINACT_MIN_AGE=7 pinact run --update",
		"update:deps": "taze --all",
		"vscode:prepublish": "npm run build",
		"watch:src": "tsc-watch -p src --onSuccess 'npm run bundle'"
	},
	"dependencies": {},
	"devDependencies": {
		"@commitlint/cli": "20.5.3",
		"@commitlint/config-conventional": "20.5.3",
		"@types/node": "20.19.43",
		"@types/vscode": "1.56.0",
		"@vercel/ncc": "0.44.0",
		"@vscode/vsce": "3.9.2",
		"fixpack": "4.0.0",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"release-it": "20.2.0",
		"rimraf": "6.1.3",
		"taze": "19.14.1",
		"tsc-watch": "7.2.0",
		"typescript": "5.9.3",
		"xo": "0.60.0"
	},
	"overrides": {
		"release-it": {
			"undici": "7.28.0"
		}
	},
	"allowScripts": {
		"@vscode/vsce-sign": true,
		"keytar": true
	},
	"activationEvents": [
		"onLanguage:markdown",
		"onLanguage:mdx",
		"onLanguage:quarto"
	],
	"capabilities": {
		"virtualWorkspaces": true,
		"untrustedWorkspaces": {
			"supported": true
		}
	},
	"contributes": {
		"commands": [
			{
				"command": "markdownRankingTable.clearRankings",
				"title": "Markdown Ranking Table: Clear Rankings"
			},
			{
				"command": "markdownRankingTable.moveRankingDown",
				"title": "Markdown Ranking Table: Move Ranking Down"
			},
			{
				"command": "markdownRankingTable.moveRankingUp",
				"title": "Markdown Ranking Table: Move Ranking Up"
			},
			{
				"command": "markdownRankingTable.normalizeRankings",
				"title": "Markdown Ranking Table: Normalize Rankings"
			},
			{
				"command": "markdownRankingTable.setRanking",
				"title": "Markdown Ranking Table: Set Ranking"
			}
		],
		"configuration": {
			"title": "Markdown Ranking Table",
			"properties": {
				"markdownRankingTable.notification": {
					"type": "string",
					"enum": [
						"none",
						"major",
						"minor",
						"patch"
					],
					"default": "minor",
					"description": "Display notification when a new version is installed",
					"enumDescriptions": [
						"The new version notification won't be shown anymore.",
						"The new version notification will be shown only with a new major version",
						"The new version notification will be shown only with a new minor version",
						"The new version notification will always be shown"
					],
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownRankingTable.showMenu.clearRankings": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Clear Rankings\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				},
				"markdownRankingTable.showMenu.normalizeRankings": {
					"type": "boolean",
					"default": true,
					"description": "Show command in context menu: \"Normalize Rankings\".",
					"scope": "application",
					"tags": [
						"markdown",
						"table"
					]
				}
			}
		},
		"keybindings": [
			{
				"command": "markdownRankingTable.clearRankings",
				"key": "alt+w",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownRankingTable.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownRankingTable.moveRankingUp",
				"key": "alt+up",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownRankingTable.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownRankingTable.moveRankingDown",
				"key": "alt+down",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownRankingTable.contextkey.selection.InMarkdownTable"
			},
			{
				"command": "markdownRankingTable.setRanking",
				"key": "alt+s",
				"when": "editorTextFocus && !editorReadonly && !editorTabMovesFocus && !suggestWidgetMultipleSuggestions && !suggestWidgetVisible && !inSnippetMode && markdownRankingTable.contextkey.selection.InMarkdownTable"
			}
		],
		"menus": {
			"editor/context": [
				{
					"when": "markdownRankingTable.contextkey.active.IsSupportedLanguage && markdownRankingTable.contextkey.selection.InMarkdownTable && markdownRankingTable.contextkey.config.showMenu.clearRankings",
					"command": "markdownRankingTable.clearRankings",
					"group": "markdownRankingTable@1"
				},
				{
					"when": "markdownRankingTable.contextkey.active.IsSupportedLanguage && markdownRankingTable.contextkey.selection.InMarkdownTable && markdownRankingTable.contextkey.config.showMenu.normalizeRankings",
					"command": "markdownRankingTable.normalizeRankings",
					"group": "markdownRankingTable@2"
				}
			]
		}
	},
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#ffffff",
		"theme": "light"
	},
	"categories": [
		"Other"
	],
	"keywords": [],
	"extensionKind": [
		"ui",
		"workspace"
	]
}
